{
  "manifest_version": 3,
  "name": "UrdReplay",
  "version": "1.1.0",
  "description": "Captura errores de consola, red y graba la pantalla para debugging.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "type": "module",
    "scripts": [
      "src/background/background.js"
    ]
  },
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "activeTab",
    "scripting",
    "webRequest",
    "webNavigation",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "devjam@extension",
      "strict_min_version": "127.0"
    }
  }
}